# Backend env example for commentator integration
# Copy this file to .env and update values.

PORT=8000
DB_URI=mongodb://127.0.0.1:27017
DB_NAME=pubgbackend

# Frontend origin allowed for both REST and Socket.IO CORS
CORS_ORIGIN=http://localhost:3000

# Tournament Squad Size Configuration
# Supported values: 2 (duo mode), 4 (squad mode)
# Default: 4
# Controls player count per team across all tournament logic
TEAM_SQUAD_SIZE=4
